{
  "info": {
    "_postman_id": "b5c8d39c-9f5d-4d2b-84f6-6c0c8d3e5a4d",
    "name": "Movie Recommendation System API",
    "description": "Local Postman collection for the movie recommendation backend.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.environment.get('userId')) {",
          "  pm.environment.set('userId', 'user_' + Math.random().toString(36).slice(2, 11));",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Movies",
      "item": [
        {
          "name": "Get All Movies",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-user-id",
                "value": "{{userId}}"
              }
            ],
            "url": "{{baseUrl}}/movies"
          }
        },
        {
          "name": "Get Movie By ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-user-id",
                "value": "{{userId}}"
              }
            ],
            "url": "{{baseUrl}}/movies/{{movieId}}"
          }
        },
        {
          "name": "Search Movies",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-user-id",
                "value": "{{userId}}"
              }
            ],
            "url": "{{baseUrl}}/search?q={{query}}"
          }
        },
        {
          "name": "Get Movies By Genre",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-user-id",
                "value": "{{userId}}"
              }
            ],
            "url": "{{baseUrl}}/genre/{{genre}}"
          }
        },
        {
          "name": "Get Movies By Rating",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-user-id",
                "value": "{{userId}}"
              }
            ],
            "url": "{{baseUrl}}/filter/rating?min={{minRating}}&max={{maxRating}}"
          }
        }
      ]
    },
    {
      "name": "Watchlist",
      "item": [
        {
          "name": "Get Watchlist",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-user-id",
                "value": "{{userId}}"
              }
            ],
            "url": "{{baseUrl}}/watchlist"
          }
        },
        {
          "name": "Add To Watchlist",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-user-id",
                "value": "{{userId}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"movieId\": {{movieId}}\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/watchlist/add"
          }
        },
        {
          "name": "Remove From Watchlist",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-user-id",
                "value": "{{userId}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"movieId\": {{movieId}}\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/watchlist/remove"
          }
        }
      ]
    },
    {
      "name": "Seen",
      "item": [
        {
          "name": "Get Seen Movies",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-user-id",
                "value": "{{userId}}"
              }
            ],
            "url": "{{baseUrl}}/seen"
          }
        },
        {
          "name": "Toggle Seen Status",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-user-id",
                "value": "{{userId}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"movieId\": {{movieId}}\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": "{{baseUrl}}/seen/toggle"
          }
        }
      ]
    },
    {
      "name": "Stats & Health",
      "item": [
        {
          "name": "Get Stats",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-user-id",
                "value": "{{userId}}"
              }
            ],
            "url": "{{baseUrl}}/stats"
          }
        },
        {
          "name": "Frontend Home",
          "request": {
            "method": "GET",
            "url": "http://localhost:5000/"
          }
        }
      ]
    }
  ]
}